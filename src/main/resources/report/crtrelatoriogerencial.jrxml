	<parameter name="wDataInicial" class="java.lang.String"/>
	<parameter name="wDataFinal" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT * FROM nfe
       WHERE
       (to_char(ide_dhemi, 'YYYY-MM-DD') >= $P{wDataInicial} AND
        to_char(ide_dhemi, 'YYYY-MM-DD') <= $P{wDataFinal}) AND
         trim(infnfe_statusnfe) = 'Autorizada'
       ORDER BY ide_nnf ASC]]>
	</queryString>
