                                    <StringItem index="11" value="50 - Opera&#xe7;&#xe3;o com Direito a Cr&#xe9;dito - Vinculada Exclusivamente a Receita Tributada no Mercado Interno"/>
                                    <StringItem index="12" value="51 - Opera&#xe7;&#xe3;o com Direito a Cr&#xe9;dito - Vinculada Exclusivamente a Receita N&#xe3;o Tributada no Mercado Interno"/>
                                    <StringItem index="13" value="52 - Opera&#xe7;&#xe3;o com Direito a Cr&#xe9;dito &#x2013; Vinculada Exclusivamente a Receita de Exporta&#xe7;&#xe3;o"/>
