                                  <StringArray count="35">
                                    <StringItem index="0" value=" "/>
                                    <StringItem index="1" value="01 - Opera&#xe7;&#xe3;o Tribut&#xe1;vel (base de c&#xe1;lculo = valor da opera&#xe7;&#xe3;o al&#xed;quota normal (cumulativo/n&#xe3;o cumulativo))"/>
                                    <StringItem index="2" value="02 - Opera&#xe7;&#xe3;o Tribut&#xe1;vel (base de c&#xe1;lculo = valor da opera&#xe7;&#xe3;o (al&#xed;quota diferenciada))"/>
                                    <StringItem index="3" value="03 - Opera&#xe7;&#xe3;o Tribut&#xe1;vel (base de c&#xe1;lculo = quantidade vendida x al&#xed;quota por unidade de produto)"/>
                                    <StringItem index="4" value="04 - Opera&#xe7;&#xe3;o Tribut&#xe1;vel (tributa&#xe7;&#xe3;o monof&#xe1;sica, al&#xed;quota zero)"/>
                                    <StringItem index="5" value="05 - Opera&#xe7;&#xe3;o Tribut&#xe1;vel (Substitui&#xe7;&#xe3;o Tribut&#xe1;ria)"/>
                                    <StringItem index="6" value="06 - Opera&#xe7;&#xe3;o Tribut&#xe1;vel (al&#xed;quota zero)"/>
                                    <StringItem index="7" value="07 - Opera&#xe7;&#xe3;o Isenta da Contribui&#xe7;&#xe3;o"/>
